# Stage 1: Flutter Web 빌드
FROM ghcr.io/cirruslabs/flutter:3.41.2 AS flutter-build

WORKDIR /app

# pubspec 먼저 복사해서 의존성 캐시 활용
COPY pubspec.yaml pubspec.lock ./
RUN flutter pub get

# 소스 복사 및 빌드
COPY lib/ lib/
COPY web/ web/
COPY assets/ assets/
COPY font/ font/
COPY analysis_options.yaml devtools_options.yaml ./

RUN flutter build web --release

# Stage 2: Nginx로 정적 파일 서빙
FROM nginx:alpine

COPY --from=flutter-build /app/build/web /usr/share/nginx/html
